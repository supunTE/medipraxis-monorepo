{
  "expo": {
    "name": "MediPraxis",
    "slug": "medipraxis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brand-logo.png",
    "scheme": "medipraxis",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/brand-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.medipraxis.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/brand-logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/brand-logo.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5609fe88-5fe6-4fb3-8815-88552a09c3e4"
      }
    }
  }
}
