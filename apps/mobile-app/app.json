{
  "expo": {
    "name": "MediPraxis",
    "slug": "medipraxis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-brand-logo.png",
    "scheme": "medipraxis",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/brand-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.medipraxis.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-brand-logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app-brand-logo.png"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "154f9738-64fd-4fb1-91d6-b856b19cdeb0"
      }
    },
    "owner": "rashidsajahan22"
  }
}
