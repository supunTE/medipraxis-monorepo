{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Hono on Cloudflare Workers",
  "extends": "./base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "noEmit": true
  }
}
